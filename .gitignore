*.psess
*.vsp
*.psm
*.psd

# Output folders
Reports/
Output/
Logs/

# Log files
*.log
*.err
*.trace

# Temporary and backup files
*.tmp
*.temp
~$*
*.bak
*.backup
*.old

# IDE and editor files
.vs/
.vscode/
*.code-workspace
.idea/

# Windows files
Thumbs.db
ehthumbs.db
Desktop.ini

# MacOS files
.DS_Store
.AppleDouble
.LSOverride

